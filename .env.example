# Multi-Broker API Credentials
# Copy this file to .env and fill in your actual credentials

# ============================================================================
# ZERODHA ACCOUNTS (up to 4 accounts)
# ============================================================================

# Zerodha Account 1
ZERODHA_1_API_KEY=your_api_key_here
ZERODHA_1_API_SECRET=your_api_secret_here
ZERODHA_1_TOTP_SECRET=your_totp_secret_here
ZERODHA_1_ACCOUNT_NAME=your_account_name_here

# Zerodha Account 2
ZERODHA_2_API_KEY=your_api_key_here
ZERODHA_2_API_SECRET=your_api_secret_here
ZERODHA_2_TOTP_SECRET=your_totp_secret_here
ZERODHA_2_ACCOUNT_NAME=your_account_name_here

# Zerodha Account 3
ZERODHA_3_API_KEY=your_api_key_here
ZERODHA_3_API_SECRET=your_api_secret_here
ZERODHA_3_TOTP_SECRET=your_totp_secret_here
ZERODHA_3_ACCOUNT_NAME=your_account_name_here

# Zerodha Account 4
ZERODHA_4_API_KEY=your_api_key_here
ZERODHA_4_API_SECRET=your_api_secret_here
ZERODHA_4_TOTP_SECRET=your_totp_secret_here
ZERODHA_4_ACCOUNT_NAME=your_account_name_here

# ============================================================================
# ICICI DIRECT ACCOUNTS (up to 2 accounts)
# ============================================================================

# ICICI Direct Account 1
ICICI_1_API_KEY=your_api_key_here
ICICI_1_API_SECRET=your_api_secret_here
ICICI_1_TOTP_SECRET=your_totp_secret_here
ICICI_1_ACCOUNT_NAME=your_account_name_here

# ICICI Direct Account 2
ICICI_2_API_KEY=your_api_key_here
ICICI_2_API_SECRET=your_api_secret_here
ICICI_2_TOTP_SECRET=your_totp_secret_here
ICICI_2_ACCOUNT_NAME=your_account_name_here

# Optional: Custom session timeout (in seconds)
# SESSION_TIMEOUT=3600
